# Copy this file to .env and fill in your values.
# Never commit .env to version control — it contains secrets.

# ── Web UI ────────────────────────────────────────────────────────────────────
VOXRAD_WEB_PASSWORD=changeme
VOXRAD_PORT=8765

# ── Transcription ─────────────────────────────────────────────────────────────
# Groq is strongly recommended: ~200 ms latency enables 600 ms live dictation
# gaps (similar to PowerScribe One).  Free tier at https://console.groq.com
VOXRAD_TRANSCRIPTION_API_KEY=gsk_...
VOXRAD_TRANSCRIPTION_BASE_URL=https://api.groq.com/openai/v1
VOXRAD_TRANSCRIPTION_MODEL=whisper-large-v3-turbo

# OpenAI Whisper alternative (slower ~1-3 s, increase SILENCE_DURATION_MS to
# ~1500 in app.js if using this):
# VOXRAD_TRANSCRIPTION_API_KEY=sk-...
# VOXRAD_TRANSCRIPTION_BASE_URL=https://api.openai.com/v1
# VOXRAD_TRANSCRIPTION_MODEL=whisper-1

# ── Report formatting ─────────────────────────────────────────────────────────
VOXRAD_TEXT_API_KEY=sk-...
# Defaults to https://api.openai.com/v1 / gpt-4o-mini if not set.
# VOXRAD_TEXT_BASE_URL=https://api.openai.com/v1
# VOXRAD_TEXT_MODEL=gpt-4o-mini

# ── Encrypted-key passwords (advanced / desktop-first workflow) ───────────────
VOXRAD_TRANSCRIPTION_PASSWORD=
VOXRAD_TEXT_PASSWORD=
VOXRAD_MM_PASSWORD=
