# Copy this file to .env and fill in your values.
# Never commit .env to version control — it contains secrets.

# ── Web UI ────────────────────────────────────────────────────────────────────
# Password for the HTTP Basic Auth prompt.  Change this before deploying.
VOXRAD_WEB_PASSWORD=changeme

# Host port that maps to the container's 8765.
VOXRAD_PORT=8765

# ── API keys (plaintext) ──────────────────────────────────────────────────────
# Simplest setup: set these and leave the PASSWORD variables empty.
# The server loads them directly without the encryption wrapper.
VOXRAD_TRANSCRIPTION_API_KEY=sk-...
VOXRAD_TEXT_API_KEY=sk-...
# Gemini key — only needed when multimodal mode is enabled.
VOXRAD_MM_API_KEY=

# ── Encrypted-key passwords (advanced) ───────────────────────────────────────
# If you have pre-generated encrypted key files in the voxrad-config volume
# (e.g. copied from a desktop installation), set these passwords instead of
# the plaintext API keys above.  Leave blank when using plaintext keys.
VOXRAD_TRANSCRIPTION_PASSWORD=
VOXRAD_TEXT_PASSWORD=
VOXRAD_MM_PASSWORD=
