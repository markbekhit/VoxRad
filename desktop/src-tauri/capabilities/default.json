{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability for RadSpeed desktop",
  "windows": ["settings"],
  "permissions": [
    "core:default",
    "core:window:default",
    "core:window:allow-show",
    "core:window:allow-hide",
    "core:window:allow-close",
    "core:window:allow-set-focus",
    "core:app:default",
    "global-shortcut:default",
    "process:default",
    "opener:default",
    "opener:allow-open-url",
    "dialog:default"
  ]
}
