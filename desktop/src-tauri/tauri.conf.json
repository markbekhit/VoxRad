{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RadSpeed",
  "version": "0.2.20",
  "identifier": "com.radspeed.app",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "frontendDist": "../src",
    "devUrl": "http://localhost:1420"
  },
  "app": {
    "windows": [
      {
        "title": "RadSpeed Settings",
        "label": "settings",
        "width": 600,
        "height": 620,
        "resizable": true,
        "fullscreen": false,
        "visible": false,
        "decorations": true,
        "center": true,
        "skipTaskbar": false
      }
    ],
    "security": { "csp": null }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["nsis", "msi"],
    "category": "Productivity",
    "shortDescription": "RadSpeed desktop companion for Windows",
    "longDescription": "Global hotkey + system tray companion for the RadSpeed cloud workstation. Generate guideline-aware impressions inline with PowerScribe One and other dictation apps.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "windows": {
      "wix": { "language": ["en-US"] },
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installMode": "currentUser",
        "displayLanguageSelector": false
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDYzRDFDNTQyQ0M1QTU5NDgKUldSSVdWck1Rc1hSWS9tRWNOM3cxWWVwTVVkc2ZlK0RqTjhoV3UxbzBoR2RhSFVVYkpYQ01xUGgK",
      "endpoints": [
        "https://github.com/markbekhit/VoxRad/releases/latest/download/update.json"
      ]
    }
  }
}
